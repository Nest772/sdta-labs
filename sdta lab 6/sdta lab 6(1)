#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

const int MAX = 100;

struct Stack {
    double arr[MAX];
    int top;
};

void init(Stack &s) { s.top = -1; }
bool empty(Stack s) { return s.top == -1; }

void push(Stack &s, double x) {
    if (s.top < MAX - 1)
        s.arr[++s.top] = x;
}

double pop(Stack &s) {
    if (!empty(s))
        return s.arr[s.top--];
    return 0;
}


void print(Stack s) {
    if (empty(s)) {
        cout << "Stack is empty\n";
        return;
    }

    cout << "Stack: ";
    for (int i = s.top; i >= 0; i--) {
        cout << s.arr[i] << " ";
    }
    cout << endl;
}

int main() {
    srand(time(0));

    Stack s, newS;
    init(s); 
    init(newS);

    int n = 10;
    double limit;

    cout << "Enter limit: ";
    cin >> limit;

    
    for (int i = 0; i < n; i++) {
        double x = -6 + rand() % 18;
        push(s, x);
    }

    cout << "\nBefore delete:\n";
    print(s);

    
    while (!empty(s)) {
        double x = pop(s);
        if (x >= limit)
            push(newS, x);
    }

    cout << "\nAfter delete (new stack):\n";
    print(newS);

    
    double sum = 0; 
    int count = 0;

    while (!empty(newS)) {
        double x = pop(newS);
        sum += x;
        count++;
    }

    if (count > 0)
        cout << "\nAverage = " << sum / count << endl;
    else
        cout << "\nNo elements\n";

    return 0;
}
