#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
};


void addEnd(Node*& head, int value) {
    Node* newNode = new Node{value, NULL};
    if (!head) {
        head = newNode;
        return;
    }
    Node* temp = head;
    while (temp->next) temp = temp->next;
    temp->next = newNode;
}


void printList(Node* head) {
    while (head) {
        cout << head->data << " ";
        head = head->next;
    }
    cout << endl;
}


double countAverage(Node* head) {
    int sum = 0, count = 0;
    while (head) {
        sum += head->data;
        count++;
        head = head->next;
    }
    return (double)sum / count;
}


void deleteFirstEven(Node*& head) {
    if (!head) return;

    if (head->data % 2 == 0) {
        Node* temp = head;
        head = head->next;
        delete temp;
        return;
    }

    Node* temp = head;
    while (temp->next && temp->next->data % 2 != 0) {
        temp = temp->next;
    }

    if (temp->next) {
        Node* del = temp->next;
        temp->next = del->next;
        delete del;
    }
}


void clearList(Node*& head) {
    while (head) {
        Node* temp = head;
        head = head->next;	
        delete temp;
    }
}

int main() {
    Node* head = NULL;

    addEnd(head, 3);
    addEnd(head, 8);
    addEnd(head, 5);
    addEnd(head, 2);

    printList(head);

    cout << "Average: " << countAverage(head) << endl;

    deleteFirstEven(head);

    printList(head);

    clearList(head);
    
    return 0;
}
