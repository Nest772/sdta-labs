#include <iostream>
using namespace std;

const int MAX = 100;

class Stack {
private:
    int arr[MAX];
    int top;

public:
    Stack() {
        top = -1;
    }

    bool isEmpty() {
        return top == -1;
    }

    bool isFull() {
        return top == MAX - 1;
    }

    void push(int x) {
        if (isFull()) {
            cout << "Stek is full\n";
            return;
        }
        arr[++top] = x;
    }

    int pop() {
        if (isEmpty()) {
            cout << "Stek is empty\n";
            return -1;
        }
        return arr[top--];
    }

    void show() {
        if (isEmpty()) {
            cout << "Stek is empty\n";
            return;
        }

        cout << "stek elements:\n";
        for (int i = top; i >= 0; i--) {
            cout << arr[i] << " ";
        }
        cout << endl;
    }

    double average() {
        if (isEmpty()) return 0;

        int sum = 0;
        for (int i = 0; i <= top; i++) {
            sum += arr[i];
        }
        return (double)sum / (top + 1);
    }

    void clear() {
        top = -1;
    }
};

int main() {
    Stack s;
    int n, x;

    cout << "Enter number of grades: ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        cout << "Enter grade " << i + 1 << ": ";
        cin >> x;
        s.push(x);
    }

    s.show();

    cout << "Average grade: " << s.average() << endl;

    s.clear();
    cout << "After delete:\n";
    s.show();

    return 0;
}
