#include <iostream>
#include <deque>;
using namespace std;

int main() {
    deque<string> queue;
    int choice;
    string task;

    do {
        cout << "\n1.Add normal\n2.Add urgent\n3.Process\n4.Show\n5.Count\n0.Exit\n";
        cin >> choice;

        switch (choice) {
        case 1:
            cout << "Task: "; cin >> task;
            queue.push_back(task);
            break;

        case 2:
            cout << "Urgent task: "; cin >> task;
            queue.push_front(task);
            break;

        case 3:
            if (!queue.empty()) {
                cout << "Processed: " << queue.front() << endl;
                queue.pop_front();
            }
            break;

        case 4:
            for (auto &q : queue) cout << q << " ";
            cout << endl;
            break;

        case 5:
            cout << "Count: " << queue.size() << endl;
            break;
        }

    } while (choice != 0);

    return 0;
}
