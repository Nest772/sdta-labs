#include <iostream>
#include <string>
using namespace std;

struct Node {
    string name;
    int year;
    double price;
    Node* next;
};

void addEnd(Node*& head, string name, int year, double price) {
    Node* newNode = new Node{name, year, price, NULL};
    if (!head) {
        head = newNode;
        return;
    }
    Node* temp = head;
    while (temp->next) temp = temp->next;
    temp->next = newNode;
}

void printCars(Node* head) {
    int currentYear = 2026;

    while (head) {
        if ((currentYear - head->year > 10) && head->price < 5000) {
            cout << head->name << " " << head->year << " $" << head->price << endl;
        }
        head = head->next;
    }
}

void clearList(Node*& head) {
    while (head) {
        Node* temp = head;
        head = head->next;
        delete temp;
    }
}

int main() {
    Node* head = NULL;

    addEnd(head, "BMW", 2010, 4500);
    addEnd(head, "Audi", 2018, 7000);
    addEnd(head, "Ford", 2005, 3000);

    printCars(head);

    clearList(head);
    
    return 0;
}
