#include <iostream>
#include <set>
#include <unordered_set>
#include <chrono>
using namespace std;
using namespace chrono;

int main() {
    int N, K;
    cout << "Enter N: ";
    cin >> N;

    set<string> s;
    unordered_set<string> us;

    string word;

    
    auto start1 = high_resolution_clock::now();
    for (int i = 0; i < N; i++) {
        cin >> word;
        s.insert(word);
    }
    auto end1 = high_resolution_clock::now();

    auto start2 = high_resolution_clock::now();
    for (int i = 0; i < N; i++) {
        us.insert(word);
    }
    auto end2 = high_resolution_clock::now();

    cout << "Set insert time: "
         << duration_cast<microseconds>(end1 - start1).count() << endl;

    cout << "Unordered_set insert time: "
         << duration_cast<microseconds>(end2 - start2).count() << endl;

    cout << "Enter K: ";
    cin >> K;

    for (int i = 0; i < K; i++) {
        cin >> word;

        cout << "set: " << (s.count(word) ? "Found" : "Not found") << endl;
        cout << "unordered_set: " << (us.count(word) ? "Found" : "Not found") << endl;
    }

    return 0;
}
